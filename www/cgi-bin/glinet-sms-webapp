#!/bin/sh
# GL.iNet SMS Tool Web App CGI endpoint.
# This GL.iNet sendsms wrapper reads the actual SMS text from stdin.

umask 077
MAX_BODY=1000
CONFIG_NAME='glinet_sms_webapp'
DEFAULT_SPOOL='/etc/spool/sms'
SEND_LOG='/tmp/glinet-sms-webapp-send.log'

json_header() {
    printf 'Content-Type: application/json\r\nCache-Control: no-store\r\n\r\n'
}

json_escape() {
    awk 'BEGIN { first = 1 }
         {
           if (!first) printf "\\n"
           first = 0
           gsub(/\\/, "\\\\")
           gsub(/"/, "\\\"")
           gsub(/\t/, "\\t")
           gsub(/\r/, "")
           printf "%s", $0
         }'
}

json_string() { printf '%s' "$1" | json_escape; }

spool_base() {
    base="$(uci -q get "$CONFIG_NAME.settings.spool_base" 2>/dev/null || true)"
    [ -n "$base" ] || base="$DEFAULT_SPOOL"
    printf '%s' "$base"
}

field() {
    awk -v name="$2" 'index($0, name ":") == 1 { sub("^[^:]*:[[:space:]]*", ""); print; exit }' "$1" 2>/dev/null
}

message_body() { sed '1,/^$/d' "$1" 2>/dev/null; }

list_messages() {
    case "$1" in
        incoming|storage|sent|failed) box="$1" ;;
        *) box='incoming' ;;
    esac
    directory="$(spool_base)/$box"

    json_header
    [ -d "$directory" ] || { printf '{"ok":true,"box":"%s","messages":[]}\n' "$box"; return; }

    printf '{"ok":true,"box":"%s","messages":[' "$box"
    first=1
    for name in $(ls -1t "$directory" 2>/dev/null); do
        f="$directory/$name"
        [ -f "$f" ] || continue
        from="$(field "$f" From)"
        to="$(field "$f" To)"
        received="$(field "$f" Received)"
        sent="$(field "$f" Sent)"
        modem="$(field "$f" Modem)"
        [ -n "$modem" ] || modem="$(field "$f" Subject)"
        text="$(message_body "$f")"
        [ "$first" = 1 ] || printf ','
        first=0
        printf '{"file":"%s","from":"%s","to":"%s","received":"%s","sent":"%s","modem":"%s","body":"%s"}' \
            "$(json_string "$name")" "$(json_string "$from")" "$(json_string "$to")" \
            "$(json_string "$received")" "$(json_string "$sent")" "$(json_string "$modem")" \
            "$(json_string "$text")"
    done
    printf ']}\n'
}

url_decode() {
    input="$1"
    output=''
    while [ -n "$input" ]; do
        case "$input" in
            +*) output="$output "; input=${input#?} ;;
            %??*)
                hex="$(printf '%s' "$input" | cut -c 2-3)"
                case "$hex" in
                    [0-9A-Fa-f][0-9A-Fa-f])
                        decimal="$(printf '%d' "0x$hex" 2>/dev/null || true)"
                        octal="$(printf '%03o' "$decimal")"
                        output="$output$(printf "\\$octal")"
                        input="$(printf '%s' "$input" | cut -c 4-)"
                        ;;
                    *) output="$output%"; input=${input#?} ;;
                esac
                ;;
            *)
                character="$(printf '%s' "$input" | cut -c 1)"
                output="$output$character"
                input=${input#?}
                ;;
        esac
    done
    printf '%s' "$output"
}

form_value() {
    wanted="$1"
    raw="$(printf '%s' "$POST_DATA" | tr '&' '\n' | sed -n "s/^$wanted=//p" | head -n 1)"
    url_decode "$raw"
}

send_sms() {
    [ "${REQUEST_METHOD:-GET}" = 'POST' ] || { json_header; printf '{"ok":false,"error":"POST required"}\n'; return; }

    length="${CONTENT_LENGTH:-0}"
    case "$length" in ''|*[!0-9]*) length=0 ;; esac
    POST_DATA="$(dd bs=1 count="$length" 2>/dev/null)"

    to="$(form_value to | tr -cd '0-9+')"
    text="$(form_value text | head -c "$MAX_BODY")"

    json_header
    [ -n "$to" ] || { printf '{"ok":false,"error":"Destination number is required"}\n'; return; }
    [ -n "$text" ] || { printf '{"ok":false,"error":"Message text is required"}\n'; return; }

    sender="$(command -v sendsms 2>/dev/null || true)"
    [ -n "$sender" ] || sender='/usr/bin/sendsms'
    [ -x "$sender" ] || { printf '{"ok":false,"error":"GL.iNet sendsms utility was not found"}\n'; return; }

    # Mirrors the known-working interactive command:
    # sendsms DESTINATION "message" international
    # The wrapper then asks for Text; piping supplies that prompt noninteractively.
    result="$(printf '%s\n' "$text" | "$sender" "$to" "$text" international 2>&1)"
    status=$?
    printf '[%s] to=%s status=%s output=%s\n' "$(date '+%F %T')" "$to" "$status" "$result" >> "$SEND_LOG"

    if [ "$status" -eq 0 ]; then
        printf '{"ok":true,"queued":true,"message":"SMS queued through GL.iNet sendsms"}\n'
    else
        printf '{"ok":false,"error":"sendsms failed: %s"}\n' "$(json_string "$result")"
    fi
}

query_value() {
    printf '%s' "${QUERY_STRING:-}" | tr '&' '\n' | sed -n "s/^$1=//p" | head -n 1
}

action="$(query_value action)"
case "$action" in
    send) send_sms ;;
    list|*) list_messages "$(query_value box)" ;;
esac
